function WaitForLeaderboard() {
    return new Promise((resolve, reject) => {
        const interval = setInterval(() => {
            if (leaderboard !== null) { clearInterval(interval); clearTimeout(timeout); resolve(); }
        }, 100);
        const timeout = setTimeout(() => { clearInterval(interval); reject(new Error("Leaderboard timeout")); }, 5000);
    });
}

async function GetLeaderboardScores(nameLB, maxPlayers, quantityTop, quantityAround, photoSize, auth) {
    try {
        if (leaderboard === null) await WaitForLeaderboard();
        var je = { technoName:'', isDefault:false, isInvertSortOrder:false, decimalOffset:0, type:'' };
        ysdk.getLeaderboards()
            .then(lb => lb.getLeaderboardDescription(nameLB))
            .then(res => {
                je.technoName=nameLB; je.isDefault=res.default;
                je.isInvertSortOrder=res.description.invert_sort_order;
                je.decimalOffset=res.description.score_format.options.decimal_offset;
                je.type=res.description.type;
                return leaderboard.getLeaderboardEntries(nameLB, { quantityTop:quantityTop, includeUser:auth, quantityAround:quantityAround });
            })
            .then(res => {
                myGameInstance.SendMessage('YandexGame', 'LeaderboardEntries', JSON.stringify({ ...je, ...EntriesLB(res, maxPlayers, photoSize) }));
            })
            .catch(e => { console.error(e); });
    } catch (e) {}
}

async function SetLeaderboardScores(_name, score) {
    try {
        if (leaderboard === null) await WaitForLeaderboard();
        ysdk.getLeaderboards().then(lb => { lb.setLeaderboardScore(_name, score); });
    } catch (e) {}
}

function EntriesLB(res, maxPlayers, photoSize) {
    var text='', c=Math.min(res.entries.length, maxPlayers);
    var ranks=new Array(c),photos=new Array(c),names=new Array(c),scores=new Array(c),uids=new Array(c);
    for(var i=0;i<c;i++){
        ranks[i]=res.entries[i].rank; scores[i]=res.entries[i].score;
        uids[i]=res.entries[i].player.uniqueID; photos[i]=res.entries[i].player.getAvatarSrc(photoSize);
        names[i]=res.entries[i].player.scopePermissions.public_name!=="allow"?"anonymous":res.entries[i].player.publicName;
        text+=ranks[i]+'. '+names[i]+": "+scores[i]+'\n';
    }
    if(c===0)text='no data';
    return{"entries":text,"ranks":ranks,"photos":photos,"names":names,"scores":scores,"uniqueIDs":uids};
}

