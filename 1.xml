var environmentData = 'null';

function RequestingEnvironmentData(sendback) {
    return new Promise((resolve) => {
        if (ysdk == null) { resolve('null'); return; }
        try {
            ysdk.feedback.canReview().then(({ value }) => {
                var reviewCanShow = !!value;
                ysdk.shortcut.canShowPrompt().then(prompt => {
                    var promptCanShow = !!(prompt.canShow);
                    var browser = navigator.userAgent;
                    if (browser.includes('Chrome')) browser='Chrome';
                    else if (browser.includes('Firefox')) browser='Firefox';
                    else if (browser.includes('Safari')) browser='Safari';
                    else if (browser.includes('Edge')) browser='Edge';
                    else browser='Other';
                    let je = {
                        "language":ysdk.environment.i18n.lang,"domain":ysdk.environment.i18n.tld,
                        "deviceType":ysdk.deviceInfo.type,"isMobile":ysdk.deviceInfo.isMobile(),
                        "isDesktop":ysdk.deviceInfo.isDesktop(),"isTablet":ysdk.deviceInfo.isTablet(),
                        "isTV":ysdk.deviceInfo.isTV(),"appID":ysdk.environment.app.id,
                        "browserLang":ysdk.environment.browser.lang,"payload":ysdk.environment.payload,
                        "promptCanShow":promptCanShow,"reviewCanShow":reviewCanShow,
                        "platform":navigator.platform,"browser":browser
                    };
                    if (sendback) myGameInstance.SendMessage('YandexGame', 'SetEnvirData', JSON.stringify(je));
                    resolve(JSON.stringify(je));
                });
            });
        } catch (e) { resolve('null'); }
    });
}

// ================================================================
// BEFOREUNLOAD - kaydet
// ================================================================
window.addEventListener('beforeunload', (event) => {
    if (myGameInstance != null) myGameInstance.SendMessage('YandexGame', '_SaveProgress');
});

// ================================================================
// PLAYER / AUTH
// ================================================================
var playerData = 'noData';

function InitPlayer(sendback) {
    return new Promise((resolve) => {
        try {
            if (ysdk == null) {
                var na = NotAuthorized();
                if (sendback) myGameInstance.SendMessage('YandexGame', 'SetInitializationSDK', na);
                resolve(na);
            } else {
                let _scopes = true;
                ysdk.getPlayer({ scopes: _scopes }).then(_player => {
                    player = _player;
                    let playerName = player.getName();
                    let playerPhoto = player.getPhoto('small');
                    if (!_scopes) { playerName = "anonymous"; playerPhoto = "null"; }

                    if (player.getMode() === 'lite') {
                        var na = NotAuthorized();
                        if (sendback) myGameInstance.SendMessage('YandexGame', 'SetInitializationSDK', na);
                        resolve(na);
                    } else {
                        let aj = {
                            "playerAuth":"resolved","playerName":playerName,
                            "playerId":player.getUniqueID(),"playerPhoto":playerPhoto,
                            "payingStatus":player.getPayingStatus()
                        };
                        if (sendback) myGameInstance.SendMessage('YandexGame', 'SetInitializationSDK', JSON.stringify(aj));
                        resolve(JSON.stringify(aj));
                    }
                }).catch(e => {
                    var na = NotAuthorized();
                    if (sendback) myGameInstance.SendMessage('YandexGame', 'SetInitializationSDK', na);
                    resolve(na);
                });
            }
        } catch (e) {
            var na = NotAuthorized();
            if (sendback) myGameInstance.SendMessage('YandexGame', 'SetInitializationSDK', na);
            resolve(na);
        }
    });
}

function NotAuthorized() {
    return JSON.stringify({
        "playerAuth":"rejected","playerName":"unauthorized",
        "playerId":"unauthorized","playerPhoto":"unknown",
        "payingStatus": (player && player.getPayingStatus) ? player.getPayingStatus() : "unknown"
    });
}

function OpenAuthDialog() {
    if (ysdk !== null) {
        try {
            ysdk.auth.openAuthDialog().then(() => {
                InitPlayer(true).then(() => {
                    myGameInstance.SendMessage('YandexGame', 'GetDataInvoke');
                });
            });
        } catch (e) {}
    }
}

document.body.appendChild(script);
